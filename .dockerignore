# Dependencies
node_modules/
**/node_modules/

# Git
.git/
.gitignore

# Build cache
.cache/
**/.cache/

# Test artifacts
test-results/
copilotbrowser-report/


# Browser patches (not needed at runtime)
browser_patches/

# Documentation source (re-include API dirs needed by generate_types)
docs/
!docs/src/
!docs/src/api/
!docs/src/api/**
!docs/src/test-api/
!docs/src/test-api/**
!docs/src/test-reporter-api/
!docs/src/test-reporter-api/**

# Examples
examples/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS artifacts
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment files (mount these at runtime)
.env
.env.*

# TypeScript build info (regenerated during build)
*.tsbuildinfo
tsconfig.tsbuildinfo

# Test config files
tests/

# Coverage
coverage/

# Package lock files are in root
# Only root package-lock.json is needed
