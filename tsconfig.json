{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "lib": ["esnext", "dom", "DOM.Iterable"],
    "paths": {
      /*
        The following two serve different purposes:
         - @foo/* is for importing types only,
         - .../lib/* means require dependency
      */
      "@devtools/*": ["./packages/devtools/src/*"],
      "@html-reporter/*": ["./packages/html-reporter/src/*"],
      "@injected/*": ["./packages/injected/src/*"],
      "@isomorphic/*": ["./packages/copilotbrowser-core/src/utils/isomorphic/*"],
      "@protocol/*": ["./packages/protocol/src/*"],
      "@recorder/*": ["./packages/recorder/src/*"],
      "@testIsomorphic/*": ["./packages/copilotbrowser/src/isomorphic/*"],
      "@trace/*": ["./packages/trace/src/*"],
      "@web/*": ["./packages/web/src/*"],
      "copilotbrowser/lib/*": ["./packages/copilotbrowser/src/*"],
      "copilotbrowser-core/lib/*": ["./packages/copilotbrowser-core/src/*"],
    },
    "esModuleInterop": true,
    "strict": true,
    "allowJs": false,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "noEmit": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  },
  "compileOnSave": true,
  "include": ["packages"],
  "exclude": [
    "packages/*/lib",
    "packages/html-reporter/",
    "packages/vscode-extension/",
    "packages/chrome-extension/",
    "packages/electron-app/",
  ]
}
